{
    "name": "codeatlas/laravel",
    "description": "CodeAtlas Laravel bridge — ServiceProvider, artisan commands, and embedded web UI for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "keywords": ["codeatlas", "laravel", "architecture", "visualization"],
    "authors": [
        {
            "name": "Snova Labs",
            "homepage": "https://github.com/novaprime-code"
        }
    ],
    "require": {
        "php": "^8.3",
        "codeatlas/analyzer-routes": "@dev",
        "codeatlas/contracts": "@dev",
        "codeatlas/core": "@dev",
        "codeatlas/exporter-json": "@dev",
        "codeatlas/scanner": "@dev",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "CodeAtlas\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodeAtlas\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodeAtlas\\Laravel\\CodeAtlasServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
