{
  "name": "codeatlas/contracts",
  "description": "CodeAtlas contracts — interfaces, enums, and value objects that define the plugin API.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "codeatlas",
    "contracts",
    "interfaces"
  ],
  "authors": [
    {
      "name": "Snova Labs",
      "homepage": "https://github.com/novaprime-code"
    }
  ],
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "pestphp/pest": "^3.5"
  },
  "autoload": {
    "psr-4": {
      "CodeAtlas\\Contracts\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CodeAtlas\\Contracts\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
